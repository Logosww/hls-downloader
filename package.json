{
  "name": "@logosw/hls-downloader",
  "version": "1.1.0",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/Logosww/hls-downloader.git"
  },
  "workspaces": [
    "packages/*",
    "packages/app/*",
    "docs"
  ],
  "files": [
    "dist",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./adapters/wasm": {
      "types": "./dist/adapters-wasm.d.ts",
      "import": "./dist/adapters-wasm.js"
    },
    "./adapters/rust": {
      "types": "./dist/adapters-rust.d.ts",
      "import": "./dist/adapters-rust.js"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:app-web": "turbo run dev --filter=@hls-downloader/app-web",
    "dev:app-bun": "turbo run dev --filter=@hls-downloader/app-bun",
    "build": "turbo run build --filter=!@hls-downloader/app-web --filter=!@hls-downloader/docs && tsdown -c tsdown.config.ts",
    "build:all": "turbo run build --filter=!@hls-downloader/docs && tsdown -c tsdown.config.ts",
    "build:root": "tsdown -c tsdown.config.ts",
    "prepublishOnly": "pnpm run build",
    "start:app-web": "turbo run start --filter=@hls-downloader/app-web",
    "test": "turbo run test --filter=@hls-downloader/test",
    "lint": "turbo run lint",
    "changelog": "node scripts/changelog.ts",
    "changelog:append": "node scripts/changelog.ts append",
    "changelog:sync": "node scripts/changelog.ts sync",
    "version:bump": "node scripts/bump-versions.ts",
    "adapters:setup-vcpkg-ffmpeg": "node scripts/setup-vcpkg-ffmpeg.ts",
    "adapters:inject-native-pkg-repository": "node scripts/inject-rust-native-pkg-repository.ts",
    "adapters:inject-optional-deps": "node scripts/inject-adapters-optional-deps.ts",
    "adapters:verify-native-install": "node scripts/verify-adapters-native-install.ts",
    "adapters:publish-native:current-platform": "node scripts/publish-rust-native-current-platform.ts",
    "docs:dev": "turbo run dev --filter=@hls-downloader/docs",
    "docs:build": "turbo run build --filter=@hls-downloader/docs",
    "docs:preview": "turbo run preview --filter=@hls-downloader/docs"
  },
  "dependencies": {
    "@hls-downloader/adapters": "workspace:*",
    "@hls-downloader/core": "workspace:*",
    "@hls-downloader/shared": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.62.0",
    "tsdown": "^0.21.10",
    "turbo": "^2.9.6"
  },
  "peerDependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15"
  },
  "peerDependenciesMeta": {
    "@ffmpeg/ffmpeg": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0"
}
