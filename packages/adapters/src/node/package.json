{
  "name": "@hls-downloader/rust-native",
  "version": "3.0.1",
  "private": true,
  "scripts": {
    "build": "node ../../../../scripts/napi-build-adapters-native.ts",
    "build:debug": "napi build --manifest-path crates/napi/Cargo.toml --platform --js native.js --dts native.d.ts --output-dir .",
    "create:npm-dirs": "napi create-npm-dirs",
    "collect:artifacts": "napi artifacts --output-dir . --npm-dir npm",
    "prepare:prepublish": "napi pre-publish --skip-optional-publish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/node": "^25.6.0"
  },
  "napi": {
    "binaryName": "native",
    "targets": [
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc"
    ]
  }
}
