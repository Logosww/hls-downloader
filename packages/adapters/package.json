{
  "name": "@hls-downloader/adapters",
  "version": "2.0.0",
  "description": "",
  "keywords": [],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/Logosww/hls-downloader.git",
    "directory": "packages/adapters"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./browser": {
      "import": "./dist/browser.mjs",
      "types": "./dist/browser.d.mts"
    },
    "./node": {
      "import": "./dist/node.mjs",
      "types": "./dist/node.d.mts"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:native": "node ../../scripts/napi-build-adapters-native.ts",
    "build:native:static": "node ../../scripts/napi-build-adapters-native.ts --static",
    "build:ts": "tsdown -c tsdown.config.ts",
    "build:copy-native": "cp src/node/native.js src/node/native.d.ts dist/ && cp src/node/native.*.node dist/ 2>/dev/null || true",
    "build:copy-native-publish": "cp src/node/native.js src/node/native.d.ts dist/",
    "build:barrel": "printf 'export * from \"@hls-downloader/shared\";\\nexport * from \"./browser.mjs\";\\nexport * from \"./node.mjs\";\\n' | tee dist/index.mjs > dist/index.d.mts",
    "build": "pnpm run build:native && pnpm run build:ts && pnpm run build:copy-native && pnpm run build:barrel",
    "build:publish": "pnpm run build:native:static && pnpm run build:ts && pnpm run build:copy-native-publish && pnpm run build:barrel",
    "prepublishOnly": "pnpm run build:publish"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@hls-downloader/core": "workspace:*",
    "@hls-downloader/shared": "workspace:*",
    "mediabunny": "^1.50.6"
  },
  "devDependencies": {
    "@ffmpeg/util": "^0.12.2",
    "@napi-rs/cli": "^3.7.2",
    "@types/m3u8-parser": "^7.2.6",
    "@types/node": "^26.1.0",
    "m3u8-parser": "^7.2.0",
    "p-limit": "^7.3.0"
  }
}
