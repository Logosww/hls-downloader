{
  "compilerOptions": {
    "rootDir": ".",
    "declaration": true,
    "emitDeclarationOnly": true,
    "moduleResolution": "node",
    "module": "ESNext",
    "strict": true,
    "allowSyntheticDefaultImports": true,
    "isolatedDeclarations": true,
    "esModuleInterop": true,
    "target": "ESNext",
    "outDir": "dist"
  },
  "exclude": [
    "node_modules",
    "dist"
  ],
  "include": [
    "src/**/*"
  ]
}