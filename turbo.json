{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "HLS_FFMPEG_STATIC",
    "PKG_CONFIG",
    "PKG_CONFIG_PATH",
    "PKG_CONFIG_ALL_STATIC",
    "VCPKG_ROOT",
    "FFMPEG_LIBAVCODEC_MIN_MAJOR",
    "FFMPEG_LIBAVCODEC_MAX_MAJOR"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "start": {
      "dependsOn": ["build"],
      "cache": false,
      "persistent": true
    },
    "@hls-downloader/docs#build": {
      "dependsOn": [],
      "env": ["VITEPRESS_BASE"],
      "outputs": [".vitepress/dist/**"]
    },
    "@hls-downloader/docs#dev": {
      "dependsOn": [],
      "cache": false,
      "persistent": true
    },
    "@hls-downloader/docs#preview": {
      "dependsOn": ["@hls-downloader/docs#build"],
      "cache": false,
      "persistent": true
    }
  }
}
